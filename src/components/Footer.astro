---
import type { Locale } from "../i18n/locales";
import { t } from "../i18n/t";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 dark:border-zinc-800">
  <div class="site-container py-8 text-center text-xs sm:text-sm">
    <p class="mx-auto">
      <span class="font-medium">© {year} {t(lang, "siteName")}.</span>
      <span class="muted"> {t(lang, "footerCopy")}</span>
    </p>
  </div>
</footer>

---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/Section.astro";
import type { Locale } from "../../../i18n/locales";
import { t } from "../../../i18n/t";
import { assertLocale } from "../../../utils/i18n";
import { filterProjectsByLocale, getProjectLocale, getProjectSlug } from "../../../utils/projects";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects
    .map((project) => {
      const locale = getProjectLocale(project);
      if (!locale) return null;
      return {
        params: {
          lang: locale,
          slug: getProjectSlug(project),
        },
      };
    })
    .filter((path): path is { params: { lang: Locale; slug: string } } => Boolean(path));
}

const lang: Locale = assertLocale(Astro.params.lang);
const slug = Astro.params.slug;

const projects = filterProjectsByLocale(await getCollection("projects"), lang);
const project = projects.find((entry) => getProjectSlug(entry) === slug);

if (!project) {
  throw new Error(`${t(lang, "projects.errors.notFound")}: ${slug}`);
}

const { Content } = await render(project);
const contactHref = `/${lang}/#contact`;
const hasExternalLinks = Boolean(project.data.links.live || project.data.links.github);
const hasProjectMeta = Boolean(project.data.role || (project.data.impact && project.data.impact.length > 0));
---

<BaseLayout
  lang={lang}
  title={`${project.data.title} | ${t(lang, "siteName")}`}
  description={project.data.description}
  image={project.data.cover}
  type="article"
  publishedTime={project.data.date.toISOString()}
  updatedTime={project.data.date.toISOString()}
>
  <section class="pt-12 pb-8 md:pt-14 md:pb-10" data-reveal>
    <div class="site-container">
      <a href={`/${lang}/projects`} class="chip">{t(lang, "navProjects")}</a>
      <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-tight md:text-5xl">{project.data.title}</h1>
      <p class="muted mt-4 max-w-3xl text-lg">{project.data.description}</p>

      <div class="mt-6 overflow-hidden rounded-2xl border border-zinc-200 bg-white/60 p-2 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/60">
        {
          typeof project.data.cover === "string" ? (
            <img
              src={project.data.cover}
              alt={project.data.title}
              class="aspect-[16/8] w-full rounded-xl object-cover"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <Image
              src={project.data.cover}
              alt={project.data.title}
              class="aspect-[16/8] w-full rounded-xl object-cover"
              loading="lazy"
              decoding="async"
            />
          )
        }
      </div>

      <div class="mt-6 flex flex-wrap gap-2">
        {
          project.data.stack.map((item) => (
            <span class="chip">{item}</span>
          ))
        }
      </div>

      {hasExternalLinks && (
        <div class="mt-6 flex flex-wrap gap-3">
          {project.data.links.live && (
            <a href={project.data.links.live} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <use href="#icon-globe"></use>
              </svg>
              {t(lang, "projectLive")}
            </a>
          )}
          {project.data.links.github && (
            <a href={project.data.links.github} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <use href="#icon-github"></use>
              </svg>
              {t(lang, "projectGithub")}
            </a>
          )}
        </div>
      )}
    </div>
  </section>

  <section class="pt-2 pb-12 md:pb-14">
    <div class="site-container">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_290px]">
        <aside class="order-1 min-w-0 space-y-4 lg:order-2 lg:sticky lg:top-24 lg:self-start" data-reveal>
          {hasProjectMeta && (
            <div class="card space-y-3">
              {project.data.role && (
                <p>
                  <strong>{t(lang, "detailRole")}: </strong>{project.data.role}
                </p>
              )}

              {project.data.impact && project.data.impact.length > 0 && (
                <div>
                  <p><strong>{t(lang, "detailImpact")}</strong></p>
                  <ul class="mt-2 space-y-1 text-sm">
                    {
                      project.data.impact.map((item) => (
                        <li class="muted">• {item}</li>
                      ))
                    }
                  </ul>
                </div>
              )}
            </div>
          )}

          <div class="card space-y-3">
            <a href={contactHref} class="btn btn-primary w-full">{t(lang, "ctaContact")}</a>
            <a href="/cv-joel-arnaud.pdf" class="btn btn-secondary w-full" download>{t(lang, "heroDownloadCv")}</a>
          </div>
        </aside>

        <article class="prose-project order-2 min-w-0 lg:order-1" data-reveal>
          <Content />
        </article>
      </div>
    </div>
  </section>

  <Section className="pt-0 pb-20">
    <div class="card flex flex-col items-start justify-between gap-4 bg-zinc-100/70 dark:bg-zinc-900/70 md:flex-row md:items-center" data-reveal>
      <h2 class="text-2xl font-semibold">{t(lang, "talkBanner")}</h2>
      <a href={contactHref} class="btn btn-primary">{t(lang, "talkAction")}</a>
    </div>
  </Section>
</BaseLayout>
